{
	"name": "settings-page",
	"description": "Provides a proper search page",
	"version": "1.0.0",
	"author": "Magnus Anderssen <magnus@magooweb.com>",
	"contributors": [],
	"license": "agpl",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite build --mode dev",
		"build": "vite build",
		"test": " ../../bin/run-playwright.sh",
		"preview": "vite preview",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"lint:eslint": "eslint src/**/*.ts src/**/*.svelte",
		"lint": "run-p lint:eslint check",
		"upgradeDeps:major": "ncu --doctor -u",
		"upgradeDeps:minor": "ncu --doctor -u --target minor",
		"upgradeDeps": "run-s upgradeDeps:minor upgradeDeps:major",
		"prepare": "husky"
	},
	"devDependencies": {
		"@eslint/eslintrc": "3.3.5",
		"@eslint/js": "10.0.1",
		"@shared/libs": "^1.0.0",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@sveltejs/vite-plugin-svelte-inspector": "5.0.2",
		"@tailwindcss/vite": "4.3.0",
		"@tsconfig/svelte": "5.0.8",
		"@typescript-eslint/eslint-plugin": "8.61.0",
		"@typescript-eslint/parser": "8.61.0",
		"autoprefixer": "10.5.0",
		"eslint": "10.4.1",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-prettier": "5.5.6",
		"eslint-plugin-svelte": "3.19.0",
		"glob": "13.0.6",
		"globals": "17.6.0",
		"husky": "9.1.7",
		"less": "4.6.4",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "4.1.0",
		"svelte": "^5.56.3",
		"svelte-check": "4.6.0",
		"tailwindcss": "4.3.0",
		"tslib": "2.8.1",
		"typescript": "6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "8.0.16",
		"vite-plugin-css-injected-by-js": "5.0.1",
		"vite-plugin-html": "3.2.2"
	},
	"dependencies": {
		"@nextcloud/axios": "2.6.0",
		"@nextcloud/browserslist-config": "3.1.2",
		"@nextcloud/initial-state": "3.0.0",
		"@nextcloud/l10n": "3.4.1",
		"@nextcloud/router": "3.1.0",
		"npm-run-all": "4.1.5"
	}
}
